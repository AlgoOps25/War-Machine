# === ML MODELS ===
# Keep the pre-trained seed model in Git (small, ~2 MB, needed for Railway cold start).
# Exclude the live auto-retrained model — it lives on the Railway persistent volume
# and is regenerated by the EOD retrain hook; committing it would pollute history.
# NOTE: ml_model_historical.pkl is also excluded — it is auto-regenerated and
# does not need to be force-kept in git history.
models/ml_model.pkl
models/ml_model_*.pkl
models/training_dataset.csv
# Auto-generated signal predictor — excluded from git; regenerated by train_from_analytics.py
models/signal_predictor.pkl


# === BACKTEST / ANALYSIS RUN OUTPUTS ===
# These are local execution artifacts — never commit to repo.
results/
results/backtests/
results/backtests/*.json
results/backtests/*.csv
results/backtests/*.txt
